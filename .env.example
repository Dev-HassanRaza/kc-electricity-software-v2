# ============================================================
# KC Electricity Software v2 — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ── SQL Server Connection ─────────────────────────────────────
MSSQL_SERVER=localhost
MSSQL_DATABASE=Electircity
MSSQL_USER=sa
MSSQL_PASSWORD=your_sql_server_password_here
MSSQL_PORT=1433
# Set to "true" only for Azure SQL or remote servers with SSL
MSSQL_ENCRYPT=false

# ── Admin Credentials ─────────────────────────────────────────
# These are the login credentials for the web app
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── NextAuth ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-secret-string
NEXTAUTH_URL=http://localhost:3000
